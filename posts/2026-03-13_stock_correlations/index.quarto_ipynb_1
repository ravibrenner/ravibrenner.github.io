    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "stock_tickers = df[\"Name\"].unique()\n",
        "\n",
        "ticker_to_int = {ticker: i for i, ticker in enumerate(stock_tickers)}\n",
        "df[\"TickerInt\"] = df[\"Name\"].map(ticker_to_int)"
